{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://deployah.dev/schemas/platform/v1-alpha.1/platform.json",
    "title": "Deployah Platform Config",
    "description": "Platform-owned configuration file (deployah.platform.yaml). Defines Kubernetes contexts, domain bindings, storage classes per environment, and org-wide deployment profiles. Not subject to envsubst.",
    "type": "object",
    "additionalProperties": false,
    "required": ["apiVersion", "environments"],
    "properties": {
        "apiVersion": {
            "type": "string",
            "title": "API Version",
            "description": "Platform schema version. Must be 'platform/v1-alpha.1'.",
            "const": "platform/v1-alpha.1"
        },
        "profiles": {
            "type": "object",
            "title": "Profiles",
            "description": "Map of logical profile names to deployment policy. Profiles are org-wide and applied to components that list them. A profile named 'default' is prepended automatically when a component omits profiles.",
            "propertyNames": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                "minLength": 1
            },
            "additionalProperties": {
                "$ref": "#/$defs/PlatformProfile"
            },
            "examples": [
                {
                    "default": {
                        "nodeSelector": {"workload": "general"}
                    },
                    "public-web": {
                        "podLabels": {"tier": "web"},
                        "allowedDomains": ["public"]
                    }
                }
            ]
        },
        "environments": {
            "type": "object",
            "title": "Environments",
            "description": "Map of environment keys to platform configuration. Keys support prefix-based wildcard matching (e.g. 'review' matches 'review/pr-123').",
            "minProperties": 1,
            "propertyNames": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                "minLength": 2
            },
            "additionalProperties": {
                "$ref": "#/$defs/PlatformEnvironment"
            }
        }
    },
    "$defs": {
        "PlatformEnvironment": {
            "type": "object",
            "title": "Platform Environment",
            "description": "Platform-controlled settings for a single environment.",
            "additionalProperties": false,
            "properties": {
                "context": {
                    "type": "string",
                    "title": "Kubernetes Context",
                    "description": "The kubeconfig context to use when deploying to this environment.",
                    "minLength": 1,
                    "examples": ["prod-eks", "kind-deployah"]
                },
                "domains": {
                    "type": "object",
                    "title": "Domains",
                    "description": "Map of logical domain names to domain configuration. Developers reference these by key in expose.domain.",
                    "propertyNames": {
                        "type": "string",
                        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                        "minLength": 1
                    },
                    "additionalProperties": {
                        "$ref": "#/$defs/PlatformDomain"
                    }
                },
                "storageClasses": {
                    "type": "object",
                    "title": "Storage Classes",
                    "description": "Map of logical storage class names to Kubernetes storage class names.",
                    "propertyNames": {
                        "type": "string",
                        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                        "minLength": 1
                    },
                    "additionalProperties": {
                        "$ref": "#/$defs/PlatformStorageClass"
                    }
                },
                "allowStaticSubdomain": {
                    "type": "boolean",
                    "title": "Allow Static Subdomain",
                    "description": "When true, suppresses the wildcard static-subdomain warning for this environment key. Use with care: concurrent deploys to this wildcard environment may share a hostname on-cluster.",
                    "default": false,
                    "examples": [true]
                }
            },
            "examples": [
                {
                    "context": "prod-eks",
                    "domains": {
                        "public": {
                            "baseDomain": "example.com",
                            "tls": {"mode": "certManager", "issuer": "letsencrypt-prod"}
                        }
                    },
                    "storageClasses": {
                        "fast": {"className": "fast-ssd"}
                    }
                }
            ]
        },
        "PlatformDomain": {
            "type": "object",
            "title": "Platform Domain",
            "description": "Base domain and TLS configuration for a logical domain.",
            "additionalProperties": false,
            "required": ["baseDomain"],
            "properties": {
                "baseDomain": {
                    "type": "string",
                    "title": "Base Domain",
                    "description": "The DNS apex for this domain, e.g. 'example.com' or '127.0.0.1.nip.io'.",
                    "minLength": 1,
                    "examples": ["example.com", "127.0.0.1.nip.io"]
                },
                "default": {
                    "type": "boolean",
                    "title": "Default Domain",
                    "description": "Marks this domain as the one used when a component's expose block names no domain. At most one domain per environment may be the default; an environment with a single domain does not need the marker.",
                    "default": false,
                    "examples": [true]
                },
                "tls": {
                    "$ref": "#/$defs/PlatformTLS"
                }
            },
            "examples": [
                {
                    "baseDomain": "example.com",
                    "tls": {"mode": "certManager", "issuer": "letsencrypt-prod"}
                },
                {
                    "baseDomain": "127.0.0.1.nip.io",
                    "tls": {"mode": "selfSigned"}
                }
            ]
        },
        "PlatformTLS": {
            "type": "object",
            "title": "TLS Configuration",
            "description": "Explicit TLS configuration for a domain.",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
                "mode": {
                    "type": "string",
                    "title": "TLS Mode",
                    "description": "TLS provisioning strategy: selfSigned (chart-managed stable cert), secretName (pre-existing secret), or certManager (cert-manager issuer).",
                    "enum": ["selfSigned", "secretName", "certManager"]
                },
                "issuer": {
                    "type": "string",
                    "title": "Issuer",
                    "description": "cert-manager ClusterIssuer or Issuer name. Required when mode is certManager.",
                    "minLength": 1,
                    "examples": ["letsencrypt-prod", "letsencrypt-staging"]
                },
                "secretName": {
                    "type": "string",
                    "title": "Secret Name",
                    "description": "Pre-existing Kubernetes TLS secret name. Required when mode is secretName.",
                    "minLength": 1,
                    "examples": ["my-app-tls"]
                }
            },
            "examples": [
                {"mode": "certManager", "issuer": "letsencrypt-prod"},
                {"mode": "selfSigned"},
                {"mode": "secretName", "secretName": "my-app-tls"}
            ]
        },
        "PlatformStorageClass": {
            "type": "object",
            "title": "Storage Class",
            "description": "Mapping from a logical name to a Kubernetes storage class.",
            "additionalProperties": false,
            "required": ["className"],
            "properties": {
                "className": {
                    "type": "string",
                    "title": "Class Name",
                    "description": "The actual Kubernetes storage class name.",
                    "minLength": 1,
                    "examples": ["fast-ssd", "standard-hdd"]
                }
            },
            "examples": [
                {"className": "fast-ssd"},
                {"className": "standard-hdd"}
            ]
        },
        "PlatformProfile": {
            "type": "object",
            "title": "Platform Profile",
            "description": "Named deployment policy applied to components that select it.",
            "additionalProperties": false,
            "properties": {
                "nodeSelector": {
                    "type": "object",
                    "title": "Node Selector",
                    "description": "Kubernetes nodeSelector labels for pod placement.",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "examples": [{"workload": "general"}]
                },
                "tolerations": {
                    "type": "array",
                    "title": "Tolerations",
                    "description": "Kubernetes tolerations for pod scheduling.",
                    "items": {
                        "$ref": "#/$defs/PlatformToleration"
                    }
                },
                "podLabels": {
                    "type": "object",
                    "title": "Pod Labels",
                    "description": "Additional labels applied to pods.",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "podAnnotations": {
                    "type": "object",
                    "title": "Pod Annotations",
                    "description": "Additional annotations applied to pods.",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "securityContext": {
                    "type": "object",
                    "title": "Pod Security Context",
                    "description": "Kubernetes PodSecurityContext fields (pod-level). Passed through to the chart.",
                    "additionalProperties": true
                },
                "containerSecurityContext": {
                    "type": "object",
                    "title": "Container Security Context",
                    "description": "Kubernetes SecurityContext fields applied to all containers.",
                    "additionalProperties": true
                },
                "storageClass": {
                    "type": "string",
                    "title": "Storage Class",
                    "description": "Logical storage class key from the target environment's storageClasses map.",
                    "minLength": 1,
                    "examples": ["fast", "standard"]
                },
                "allowedDomains": {
                    "type": "array",
                    "title": "Allowed Domains",
                    "description": "Logical domain keys a component using this profile may expose on. Omitted means no constraint. An empty array is deny-all: no domain is allowed.",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "examples": [["public"], ["public", "internal"], []]
                },
                "maxResources": {
                    "$ref": "#/$defs/ProfileMaxResources"
                }
            },
            "examples": [
                {
                    "nodeSelector": {"workload": "general"},
                    "podLabels": {"tier": "web"},
                    "allowedDomains": ["public"]
                },
                {
                    "securityContext": {"runAsNonRoot": true},
                    "containerSecurityContext": {
                        "readOnlyRootFilesystem": true,
                        "allowPrivilegeEscalation": false
                    },
                    "maxResources": {"cpu": "1000m", "memory": "2Gi"}
                }
            ]
        },
        "PlatformToleration": {
            "type": "object",
            "title": "Toleration",
            "description": "A Kubernetes toleration entry.",
            "additionalProperties": false,
            "properties": {
                "key": {
                    "type": "string",
                    "title": "Key"
                },
                "operator": {
                    "type": "string",
                    "title": "Operator",
                    "enum": ["Equal", "Exists"]
                },
                "value": {
                    "type": "string",
                    "title": "Value"
                },
                "effect": {
                    "type": "string",
                    "title": "Effect",
                    "enum": ["NoSchedule", "PreferNoSchedule", "NoExecute"]
                }
            }
        },
        "ProfileMaxResources": {
            "type": "object",
            "title": "Profile Max Resources",
            "description": "Ceiling on component resource requests. Exceeding it is a validation error.",
            "additionalProperties": false,
            "properties": {
                "cpu": {
                    "type": "string",
                    "title": "CPU",
                    "description": "Maximum CPU request (Kubernetes quantity).",
                    "minLength": 1,
                    "examples": ["1000m", "2"]
                },
                "memory": {
                    "type": "string",
                    "title": "Memory",
                    "description": "Maximum memory request (Kubernetes quantity).",
                    "minLength": 1,
                    "examples": ["2Gi", "512Mi"]
                }
            }
        }
    },
    "examples": [
        {
            "apiVersion": "platform/v1-alpha.1",
            "profiles": {
                "default": {
                    "nodeSelector": {"workload": "general"}
                },
                "public-web": {
                    "podLabels": {"tier": "web"},
                    "allowedDomains": ["public"]
                }
            },
            "environments": {
                "production": {
                    "context": "prod-eks",
                    "domains": {
                        "public": {
                            "baseDomain": "example.com",
                            "tls": { "mode": "certManager", "issuer": "letsencrypt-prod" }
                        }
                    },
                    "storageClasses": {
                        "fast": {"className": "fast-ssd"}
                    }
                },
                "local": {
                    "context": "kind-deployah",
                    "domains": {
                        "public": {
                            "baseDomain": "127.0.0.1.nip.io",
                            "tls": { "mode": "selfSigned" }
                        }
                    }
                }
            }
        }
    ]
}
